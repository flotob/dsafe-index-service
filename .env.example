# Chain
CHAIN_ID=100
GNOSIS_RPC=https://rpc.gnosischain.com

# Swarm (shared bee node on the coolify network)
BEE_URL=http://bee:1633
# Dedicated MUTABLE postage batch (see README). Auto-selects longest-TTL funded
# batch if unset — but set it explicitly in production.
POSTAGE_BATCH_ID=

# Feed identity — pinned by clients, needs NO funds. Back up in a password manager.
FEED_SIGNER_KEY=

# Scan window (Gnosis ~5s blocks). START_BLOCK=0 → derive from LOOKBACK_BLOCKS.
START_BLOCK=0
LOOKBACK_BLOCKS=50000
WINDOW_BLOCKS=9000

INTERVAL_MINUTES=60
OUT_DIR=/data/out
STATE_FILE=/data/state.json
